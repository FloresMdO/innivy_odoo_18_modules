<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action Window-->
    <record id="hive_config_action" model="ir.actions.act_window">
        <field name="name">Configuration</field>
        <field name="res_model">hive.config</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Tree View-->
    <record id="view_hive_config_tree" model="ir.ui.view">
        <field name="name">hive.config.list</field>
        <field name="model">hive.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="hive_user_id"/>
                <field name="is_hive_enabled" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hive_config_form" model="ir.ui.view">
        <field name="name">hive.config.form</field>
        <field name="model">hive.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="My Hive Connector"/>
                        </h1>
                    </div>
                    <notebook>
                        <page name="Configuration" string="Configuration">
                            <group>
                                <group>
                                    <field name="hive_url" readonly="is_hive_enabled"/>
                                    <field name="hive_token" readonly="is_hive_enabled" password="True"/>
                                    <field name="hive_user_id" readonly="is_hive_enabled"/>
                                </group>
                                <group>
                                    <field name="is_hive_enabled" widget="boolean_toggle"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>